{
  "name": "polygon-hypersync-discovery",
  "version": "2.0.0",
  "type": "module",
  "main": "runner.ts",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.9.0"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env --import=tsx runner.ts --loop --live",
    "start:tui": "node --env-file-if-exists=.env --import=tsx runner.ts --loop --live --tui",
    "test": "env NODE_ENV=test node --import=tsx scripts/run_all_tests.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@envio-dev/hypersync-client": "^1.3.0",
    "ink": "^7.0.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^4.0.0",
    "ink-spinner": "^5.0.0",
    "ink-table": "^3.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "react": "^19.2.5",
    "viem": "^2.48.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
