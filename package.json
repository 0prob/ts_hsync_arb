{
  "name": "polygon-hypersync-discovery",
  "version": "2.0.0",
  "type": "module",
  "main": "runner.ts",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "start": "tsx runner.ts",
    "discover": "tsx runner.ts --discovery-only",
    "start:loop": "tsx runner.ts --loop",
    "start:loop:fast": "tsx runner.ts --loop --interval 5",
    "arb": "tsx runner.ts",
    "arb:loop": "tsx runner.ts --loop",
    "arb:loop:live": "tsx runner.ts --loop --live",
    "arb:loop:fast": "tsx runner.ts --loop --interval 5",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@envio-dev/hypersync-client": "^1.3.0",
    "dotenv": "^17.4.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "viem": "^2.48.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
